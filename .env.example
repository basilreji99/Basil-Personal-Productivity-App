# Copy this file to .env and fill in your own values.
# Never commit .env — it is listed in .gitignore.

# ── Google OAuth (required for Drive sync + Calendar) ─────────────────────────
# Create a Web application credential at console.cloud.google.com
# See README § 3 for full setup instructions.
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub Pages relay URL for Android OAuth (required for APK sign-in)
# See README § 3d for setup instructions.
VITE_GOOGLE_OAUTH_RELAY_URL=https://your-github-username.github.io/oauth-relay/

# ── Spotify (optional — Music tab only) ──────────────────────────────────────
# Create an app at developer.spotify.com/dashboard
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
